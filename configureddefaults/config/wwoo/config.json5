/*
WWOO Config
The config to mainly enable add-ons for William Wythers' Overhauled Overworld!
*/
{
	// This add-on modifies rivers to make them a viable method of travel.
	"navigableRivers": true,
	// This add-on makes coastlines more interesting, creating nice flat beached coves, rugged rocky escarpments, and rocky pools.
	"cliffsAndCoves": true,
	// This add-on adds tepuis to mountainous regions bordering the Jungle biome.
	"toweringTepuis": false,
	/* This removes underground ores like andesite, diorite, granite, gravel and dirt.
	   Normally these can only be found in dedicated (sub)biomes!
	*/
	"removeOres": false
}